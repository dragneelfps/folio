<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the SQLite database — contains account numbers, card numbers, balances -->
        <exclude domain="database" path="folio.db"/>
        <!-- Exclude SharedPreferences — contains the Finnhub API key -->
        <exclude domain="sharedpref" path="folio_settings.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Allow device-to-device transfer of database (same user, same device family) -->
        <include domain="database" path="folio.db"/>
        <include domain="sharedpref" path="folio_settings.xml"/>
    </device-transfer>
</data-extraction-rules>
